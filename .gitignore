# ===========================================
# Student Life OS - .gitignore
# ===========================================

# ===========================================
# .NET 8 Web API - Backend
# ===========================================

# Build outputs
bin/
obj/
*.dll
*.exe
*.pdb
*.exe.config

# User-specific and IDE files
.vs/
.vscode/
*.user
*.suo
*.userosscache

# Entity Framework Core migrations
Migrations/
*.db
*.db-shm
*.db-wal

# ===========================================
# Database - PostgreSQL
# ===========================================

# Database connection files (keep templates, ignore actual)
*.db
*.sqlite
*.sqlite

# ===========================================
# Frontend - React (Vite)
# ===========================================

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# React/Vite build outputs
dist/
build/
coverage/

# Vite
.vite/

# ===========================================
# Environment & Configuration
# ===========================================

# Environment files (keep templates, ignore actual)
appsettings.json
appsettings.Development.json
appsettings.Production.json
appsettings.Local.json

# Keep example templates
!appsettings.example.json
.env
.env.local
.env.development
.env.production

# Secrets and certificates
*.pfx
*.p12
*.pem
*.key
*.crt

# ===========================================
# Logs and Debug
# ===========================================

# Application logs
*.log
logs/

# Debug files
*.log.txt
debug/
release/

# ===========================================
# OS and System Files
# ===========================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db
desktop.ini

# Linux
*~

# ===========================================
# Temporary Files
# ===========================================

temp/
tmp/
*.tmp
*.temp
*.cache
*.swp
*.swo

# ===========================================
# Package Management
# ===========================================

# NuGet packages
packages/
*.nupkg

# Yarn/NPM
.npm
.yarn/
.yarn-integrity/

# ===========================================
# Testing and Coverage
# ===========================================

# Test results
TestResults/
*.trx
*.coverage

# Coverage reports
coverage/
*.lcov

# ===========================================
# Documentation and Tools
# ===========================================

# Generated documentation
docs/_build/

# Tool outputs
.ReSharper/
*.dotCover

# ===========================================
# Security and Sensitive Data
# ===========================================

# Backup files with sensitive data
*.bak
*.backup
*secret*
*private*

# ===========================================
# Project-Specific
# ===========================================

# Student Life OS specific
student-data/
user-uploads/
exports/

# ===========================================
# Comments for Clarity
# ===========================================

# This .gitignore covers:
# - Backend: .NET 8, EF Core, PostgreSQL
# - Frontend: React, Vite, Node.js
# - Development: IDE files, logs, temp
# - Production: Secrets, certificates, backups
# - Security: Sensitive data, environment files
# - Testing: Coverage, test results